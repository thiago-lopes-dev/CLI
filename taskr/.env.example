# Taskr Configuration
# Use this file to store sensitive data and configurations

# Database path (optional, defaults to ~/.taskr/taskr.db)
# DB_PATH=./custom.db

# API Configuration (if you ever add sync features)
# API_KEY=your_api_key_here
# SYNC_SERVER_URL=https://api.taskr.app

# Server Configuration for Web Dashboard
PORT=3000
NODE_ENV=development
